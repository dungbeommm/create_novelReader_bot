# Sao chep thanh .env va dien gia tri (KHONG commit .env len GitHub).

# Token bot Telegram lay tu @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-your-telegram-bot-token

# GitHub fine-grained PAT: quyen Contents (Read/Write) + Actions (Read/Write)
GITHUB_TOKEN=github_pat_xxx

# Repo dang owner/repo
GITHUB_REPO=your-username/piper-tts-service

# Nhanh muc tieu (mac dinh main)
GITHUB_BRANCH=main

# File workflow (mac dinh audiobook.yml)
WORKFLOW_FILE=audiobook.yml

# (Tuy chon) chi cho phep cac user id nay dung bot, ngan cach dau phay
# ALLOWED_USER_IDS=111111111,222222222
