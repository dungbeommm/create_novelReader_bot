# ---------------------------------------------------------------------------
# Audiobook Forge - environment variables
# Copy to .env for local/Docker use. NEVER commit real secrets.
# In GitHub Actions these are provided via repository Secrets instead.
# ---------------------------------------------------------------------------

# Telegram bot token from @BotFather (REQUIRED for the bot).
TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram user IDs allowed to use the bot. Empty = allow all.
TELEGRAM_ALLOWED_USER_IDS=

# GitHub Personal Access Token (repo scope) used by the bot to dispatch
# workflows and by the worker to create releases. In Actions the built-in
# GITHUB_TOKEN is used instead.
GITHUB_TOKEN=

# Target repository in "owner/name" form (used by the bot to trigger Actions).
GITHUB_REPOSITORY=your-name/audiobook-forge

# Workflow file that runs the conversion (must exist under .github/workflows).
GITHUB_WORKFLOW_FILE=convert.yml

# Git ref the workflow runs on.
GITHUB_REF=main

# Optional: override the config file path.
AUDIOBOOK_FORGE_CONFIG=config/default.yaml

# Optional: logging level (DEBUG/INFO/WARNING/ERROR).
LOG_LEVEL=INFO
